# Copy to .env and fill in. The app runs WITHOUT keys in mock mode too.
RUNPOD_API_KEY=
BRIGHTDATA_API_KEY=
BRIGHTDATA_ZONE=web_unlocker1

# Image backend: "runpod_public" (reliable, default) | "flash" | "mock"
# If RUNPOD_API_KEY is empty, it auto-falls back to mock.
IMAGE_BACKEND=runpod_public

EVENT_DEFAULT=RunPod Flash Hack Day
